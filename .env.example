# OpenZhixue Platform Environment Configuration
# Copy this file to .env and modify the values as needed

# ===========================================
# PostgreSQL Configuration
# ===========================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=openzhixue
POSTGRES_PASSWORD=openzhixue123
POSTGRES_DB=openzhixue

# Database URLs for different services
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
USERS_DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/openzhixue_users
EXAMS_DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/openzhixue_exams
ANALYTICS_DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/openzhixue_analytics

# ===========================================
# Redis Configuration
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# Redis connection pool settings
REDIS_MAX_CONNECTIONS=50
REDIS_CONNECTION_TIMEOUT=5000

# ===========================================
# RabbitMQ Configuration
# ===========================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_USER=openzhixue
RABBITMQ_PASSWORD=openzhixue123
RABBITMQ_VHOST=openzhixue

# RabbitMQ URLs
RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@${RABBITMQ_HOST}:${RABBITMQ_PORT}/${RABBITMQ_VHOST}
RABBITMQ_MGMT_URL=http://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@${RABBITMQ_HOST}:${RABBITMQ_MGMT_PORT}

# ===========================================
# MinIO Configuration
# ===========================================
MINIO_HOST=localhost
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_USER=openzhixue
MINIO_PASSWORD=openzhixue123
MINIO_USE_SSL=false

# MinIO URLs
MINIO_URL=http://${MINIO_HOST}:${MINIO_PORT}
MINIO_CONSOLE_URL=http://${MINIO_HOST}:${MINIO_CONSOLE_PORT}

# Default bucket names
MINIO_BUCKET_FILES=openzhixue-files
MINIO_BUCKET_IMAGES=openzhixue-images
MINIO_BUCKET_DOCUMENTS=openzhixue-documents

# ===========================================
# JWT Configuration
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
JWT_ALGORITHM=HS256

# ===========================================
# Application Configuration
# ===========================================
NODE_ENV=development
APP_PORT=3000
APP_HOST=localhost
API_PREFIX=/api/v1

# ===========================================
# Security Configuration
# ===========================================
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===========================================
# Logging Configuration
# ===========================================
LOG_LEVEL=debug
LOG_FORMAT=combined

# ===========================================
# Email Configuration (Optional)
# ===========================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@openzhixue.com

# ===========================================
# SMS Configuration (Optional)
# ===========================================
SMS_PROVIDER=
SMS_API_KEY=
SMS_API_SECRET=
