PORT=8084
DATABASE_URL=postgresql+asyncpg://openzhixue:openzhixue123@postgres:5432/openzhixue
DATABASE_SYNC_URL=postgresql://openzhixue:openzhixue123@postgres:5432/openzhixue
REDIS_URL=redis://redis:6379
MONGODB_URL=mongodb://admin:admin123@mongodb:27017/openzhixue?authSource=admin
MONGODB_DB_NAME=openzhixue
JWT_SECRET=your-jwt-secret-key-change-in-production
DEBUG=false

# AI Model Paths
QWEN_MODEL_PATH=./models/qwen
DEEPSEEK_OCR_MODEL_PATH=./models/deepseek-ocr

# File Storage
UPLOAD_DIR=./uploads
PAPER_STORAGE_PATH=./papers
ANALYSIS_RESULT_PATH=./analysis_results

# Model Settings
MAX_UPLOAD_SIZE=52428800
SUPPORTED_FILE_TYPES=["pdf", "docx", "doc", "txt", "png", "jpg", "jpeg"]

# OCR Settings
OCR_CONFIDENCE_THRESHOLD=0.8
OCR_LANGUAGE=ch

# Analysis Settings
MAX_CONCURRENT_TASKS=5
TASK_TIMEOUT=3600
